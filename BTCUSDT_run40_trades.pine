// ================================================================
// HPB-TCT Run 40 Trade Overlay - BTCUSDT 1h
// 238 trades | Engine v14 | Corrected exit labeling
// TCT Model + Tap 1/2/3 + Range + Fibs + Entry/Exit
//
// All markers use xloc.bar_time -> scale correctly with zoom/pan.
// Tap/model labels are price-anchored (move with candles, not screen).
//
// TradingView: Pine Editor > New Indicator > Paste > Add to Chart
// Chart: BTCUSDT 1h (Binance or MEXC)
// ================================================================
//@version=5
indicator("Run 40 - BTCUSDT", overlay=true,
     max_lines_count=500, max_labels_count=500, max_boxes_count=500)

// ---- Settings ----
grpTrade = "Trade Display"
showEntry   = input.bool(true, "Entry Markers", group=grpTrade)
showExit    = input.bool(true, "Exit Markers", group=grpTrade)
showLines   = input.bool(true, "SL / TP / TP1 Lines", group=grpTrade)
showPnL     = input.bool(true, "PnL on Exit Label", group=grpTrade)

grpTCT = "TCT Structure"
showTaps    = input.bool(true, "Tap 1 / 2 / 3 Markers", group=grpTCT)
showModel   = input.bool(true, "TCT Model Label", group=grpTCT)
showRange   = input.bool(true, "Range Box", group=grpTCT)
showFibs    = input.bool(true, "Fib Levels (0.236 - 0.786)", group=grpTCT)

grpFilter = "Filters"
filterModel = input.int(0, "Model (0=All 1=M1 2=M2 3=M3 4=M1f 5=M1C 6=M2C 7=M2E)", minval=0, maxval=7, group=grpFilter)
filterDir   = input.int(0, "Direction (0=All 1=Long 2=Short)", minval=0, maxval=2, group=grpFilter)

// ---- Colors ----
var color cLong    = #00e676
var color cShort   = #ff5252
var color cWin     = #00e676
var color cLoss    = #ff5252
var color cStop    = color.new(#ff5252, 60)
var color cTarget  = color.new(#00e676, 60)
var color cTP1     = color.new(#00bcd4, 60)
var color cTap1    = #ff9800
var color cTap2    = #ffeb3b
var color cTap3    = #e040fb
var color cModel   = #42a5f5
var color cRng     = color.new(#4fc3f7, 70)
var color cRngBg   = color.new(#4fc3f7, 93)
var color cF236    = color.new(#ef5350, 55)
var color cF382    = color.new(#ff9800, 55)
var color cF500    = color.new(#ffeb3b, 45)
var color cF618    = color.new(#ff9800, 55)
var color cF786    = color.new(#ef5350, 55)

// ---- Data Arrays ----
var int N = 238
var float[] eP  = array.new_float(0)
var float[] xP  = array.new_float(0)
var float[] sP  = array.new_float(0)
var float[] tP  = array.new_float(0)
var float[] t1P = array.new_float(0)
var int[]   oT  = array.new_int(0)
var int[]   cT  = array.new_int(0)
var int[]   sd  = array.new_int(0)
var int[]   wn  = array.new_int(0)
var int[]   er  = array.new_int(0)
var int[]   md  = array.new_int(0)
var int[]   tap1T  = array.new_int(0)
var float[] tap1P  = array.new_float(0)
var int[]   tap2T  = array.new_int(0)
var float[] tap2P  = array.new_float(0)
var int[]   tap3T  = array.new_int(0)
var float[] tap3P  = array.new_float(0)
var float[] rHi    = array.new_float(0)
var float[] rLo    = array.new_float(0)

