// ---- Helpers ----
modelName(m) =>
    m == 1 ? "M1" : m == 2 ? "M2" : m == 3 ? "M3" : m == 4 ? "M1f" : m == 5 ? "M1C" : m == 6 ? "M2C" : m == 7 ? "M2E" : "?"

exitName(e) =>
    e == 0 ? "SL" : e == 1 ? "BE" : e == 2 ? "Trail" : e == 3 ? "TP" : "End"

// ---- Main Draw Loop ----
t = time
hb = 1800000  // half-bar tolerance (30 min for 1h chart)

for i = 0 to N - 1
    _md = array.get(md, i)
    _sd = array.get(sd, i)

    // Filters
    if filterModel != 0 and _md != filterModel
        continue
    if filterDir == 1 and _sd != 1
        continue
    if filterDir == 2 and _sd != -1
        continue

    _oT  = array.get(oT, i)
    _cT  = array.get(cT, i)
    _eP  = array.get(eP, i)
    _xP  = array.get(xP, i)
    _sP  = array.get(sP, i)
    _tP  = array.get(tP, i)
    _t1  = array.get(t1P, i)
    _wn  = array.get(wn, i)
    _er  = array.get(er, i)
    _rHi = array.get(rHi, i)
    _rLo = array.get(rLo, i)

    // Offset for label stacking: small % of range so labels don't overlap
    _rngSize = _rHi > 0 and _rLo > 0 ? _rHi - _rLo : _eP * 0.005
    _nudge   = _rngSize * 0.15

    mStr = modelName(_md)
    rStr = exitName(_er)
    dStr = _sd == 1 ? "LONG" : "SHORT"
    dCol = _sd == 1 ? cLong : cShort

    // ════════════════════════════════════════════════
    // TAP MARKERS (anchored to tap time + tap price)
    // ════════════════════════════════════════════════
    if showTaps
        _t1T = array.get(tap1T, i)
        _t1P = array.get(tap1P, i)
        _t2T = array.get(tap2T, i)
        _t2P = array.get(tap2P, i)
        _t3T = array.get(tap3T, i)
        _t3P = array.get(tap3P, i)

        if _t1T > 0 and t >= _t1T - hb and t <= _t1T + hb
            label.new(_t1T, _t1P, text="T1", xloc=xloc.bar_time,
                 style=_sd == 1 ? label.style_label_up : label.style_label_down,
                 color=cTap1, textcolor=color.black, size=size.tiny)

        if _t2T > 0 and t >= _t2T - hb and t <= _t2T + hb
            label.new(_t2T, _t2P, text="T2", xloc=xloc.bar_time,
                 style=_sd == 1 ? label.style_label_up : label.style_label_down,
                 color=cTap2, textcolor=color.black, size=size.tiny)

        if _t3T > 0 and t >= _t3T - hb and t <= _t3T + hb
            label.new(_t3T, _t3P, text="T3", xloc=xloc.bar_time,
                 style=_sd == 1 ? label.style_label_up : label.style_label_down,
                 color=cTap3, textcolor=color.black, size=size.tiny)

    // ════════════════════════════════════════════════
    // RANGE BOX + FIBS (from tap1 time to entry time)
    // ════════════════════════════════════════════════
    _t1T_r = array.get(tap1T, i)
    if _rHi > 0 and _rLo > 0 and _t1T_r > 0
        _rs = _t1T_r
        _re = _oT

        if showRange and t >= _rs and t <= _rs + hb
            box.new(_rs, _rHi, _re, _rLo, xloc=xloc.bar_time,
                 border_color=cRng, border_width=1, bgcolor=cRngBg)

        if showFibs and t >= _rs and t <= _rs + hb
            _d = _rHi - _rLo
            _f236 = _rLo + _d * 0.236
            _f382 = _rLo + _d * 0.382
            _f500 = _rLo + _d * 0.5
            _f618 = _rLo + _d * 0.618
            _f786 = _rLo + _d * 0.786
            line.new(_rs, _f236, _re, _f236, xloc=xloc.bar_time, color=cF236, style=line.style_dotted, width=1)
            line.new(_rs, _f382, _re, _f382, xloc=xloc.bar_time, color=cF382, style=line.style_dotted, width=1)
            line.new(_rs, _f500, _re, _f500, xloc=xloc.bar_time, color=cF500, style=line.style_dotted, width=1)
            line.new(_rs, _f618, _re, _f618, xloc=xloc.bar_time, color=cF618, style=line.style_dotted, width=1)
            line.new(_rs, _f786, _re, _f786, xloc=xloc.bar_time, color=cF786, style=line.style_dotted, width=1)
            // Fib labels at range end (right side)
            label.new(_re, _f236, text=".236", xloc=xloc.bar_time, style=label.style_none, textcolor=cF236, size=size.tiny)
            label.new(_re, _f382, text=".382", xloc=xloc.bar_time, style=label.style_none, textcolor=cF382, size=size.tiny)
            label.new(_re, _f500, text=".5  ", xloc=xloc.bar_time, style=label.style_none, textcolor=cF500, size=size.tiny)
            label.new(_re, _f618, text=".618", xloc=xloc.bar_time, style=label.style_none, textcolor=cF618, size=size.tiny)
            label.new(_re, _f786, text=".786", xloc=xloc.bar_time, style=label.style_none, textcolor=cF786, size=size.tiny)

    // ════════════════════════════════════════════════
    // TCT MODEL LABEL (at entry bar, offset above/below range)
    // ════════════════════════════════════════════════
    if showModel and t >= _oT - hb and t <= _oT + hb
        _mY = _sd == 1 ? _rLo - _nudge * 2 : _rHi + _nudge * 2
        if _rHi == 0
            _mY := _sd == 1 ? _eP - _nudge * 3 : _eP + _nudge * 3
        label.new(_oT, _mY, text=mStr + " " + dStr,
             xloc=xloc.bar_time, style=label.style_none,
             textcolor=cModel, size=size.normal)

    // ════════════════════════════════════════════════
    // ENTRY MARKER
    // ════════════════════════════════════════════════
    if showEntry and t >= _oT - hb and t <= _oT + hb
        _eSty = _sd == 1 ? label.style_label_up : label.style_label_down
        label.new(_oT, _eP, text=str.tostring(_eP, "#.#"),
             xloc=xloc.bar_time, style=_eSty,
             color=dCol, textcolor=color.white, size=size.small)

    // ════════════════════════════════════════════════
    // EXIT MARKER
    // ════════════════════════════════════════════════
    if showExit and t >= _cT - hb and t <= _cT + hb
        _rCol = _wn == 1 ? cWin : cLoss
        _pnl = _sd == 1 ? (_xP - _eP) / _eP * 100 : (_eP - _xP) / _eP * 100
        _pStr = (showPnL ? " " + (_pnl >= 0 ? "+" : "") + str.tostring(_pnl, "#.##") + "%" : "")
        _xSty = _wn == 1 ? label.style_label_down : label.style_label_up
        label.new(_cT, _xP, text=rStr + _pStr,
             xloc=xloc.bar_time, style=_xSty,
             color=_rCol, textcolor=color.white, size=size.tiny)

    // ════════════════════════════════════════════════
    // SL / TP / TP1 / ENTRY LINES
    // ════════════════════════════════════════════════
    if showLines and t >= _oT and t <= _oT + hb
        line.new(_oT, _eP, _cT, _eP, xloc=xloc.bar_time, color=dCol, style=line.style_solid, width=2)
        line.new(_oT, _sP, _cT, _sP, xloc=xloc.bar_time, color=cStop, style=line.style_dashed, width=1)
        line.new(_oT, _tP, _cT, _tP, xloc=xloc.bar_time, color=cTarget, style=line.style_dashed, width=1)
        if _t1 > 0
            line.new(_oT, _t1, _cT, _t1, xloc=xloc.bar_time, color=cTP1, style=line.style_dotted, width=1)

// ---- Table: Run 40 Summary (top-right, always visible) ----
var table tbl = table.new(position.top_right, 2, 8, bgcolor=color.new(#161b22, 10), border_width=1, border_color=color.new(#30363d, 50))
if barstate.islast
    table.cell(tbl, 0, 0, "Run 40", text_color=#58a6ff, text_size=size.small)
    table.cell(tbl, 1, 0, "BTCUSDT 1h", text_color=#c9d1d9, text_size=size.small)
    table.cell(tbl, 0, 1, "Trades", text_color=#8b949e, text_size=size.tiny)
    table.cell(tbl, 1, 1, "238", text_color=#c9d1d9, text_size=size.tiny)
    table.cell(tbl, 0, 2, "Win Rate", text_color=#8b949e, text_size=size.tiny)
    table.cell(tbl, 1, 2, "90.3%", text_color=#00e676, text_size=size.tiny)
    table.cell(tbl, 0, 3, "Return", text_color=#8b949e, text_size=size.tiny)
    table.cell(tbl, 1, 3, "1045%", text_color=#00e676, text_size=size.tiny)
    table.cell(tbl, 0, 4, "Max DD", text_color=#8b949e, text_size=size.tiny)
    table.cell(tbl, 1, 4, "3.31%", text_color=#ffeb3b, text_size=size.tiny)
    table.cell(tbl, 0, 5, "PF", text_color=#8b949e, text_size=size.tiny)
    table.cell(tbl, 1, 5, "11.86", text_color=#c9d1d9, text_size=size.tiny)
    table.cell(tbl, 0, 6, "Trail Factor", text_color=#8b949e, text_size=size.tiny)
    table.cell(tbl, 1, 6, "0.50", text_color=#c9d1d9, text_size=size.tiny)
    table.cell(tbl, 0, 7, "Engine", text_color=#8b949e, text_size=size.tiny)
    table.cell(tbl, 1, 7, "v14", text_color=#c9d1d9, text_size=size.tiny)
