# ── Application ───────────────────────────────────────────────────────
PORT=8000
LOG_LEVEL=info
API_URL=http://127.0.0.1:8000

# ── Exchange API ───────────────────────────────────────────────────────
PHEMEX_API_KEY=your_phemex_api_key
PHEMEX_API_SECRET=your_phemex_api_secret
TELEGRAM_BOT_TOKEN=your_telegram_bot_token

# ── Backtest Database (PostgreSQL) ────────────────────────────────────
# Local Docker: set BACKTEST_DB_HOST=localhost, BACKTEST_DB_PASSWORD=your_local_pw
# Remote Render: set BACKTEST_DB_HOST=<render-host>.render.com, etc.
BACKTEST_DB_NAME=first_db_local
BACKTEST_DB_USER=bulldog
BACKTEST_DB_PASSWORD=your_db_password
BACKTEST_DB_HOST=localhost
BACKTEST_DB_PORT=5432
