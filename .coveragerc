[run]
source = .
omit =
    */tests/*
    */test/*
    */.venv/*
    */venv/*
    */__pycache__/*
    */site-packages/*
    */High_Probability_Model_v17/__init__.py
    gym_fix.py
    fixup.sh

[report]
exclude_lines =
    pragma: no cover
    def __repr__
    def __str__
    raise AssertionError
    raise NotImplementedError
    if __name__ == .__main__.:
    if TYPE_CHECKING:
    @abstractmethod
    @abc.abstractmethod

precision = 2
show_missing = True

[html]
directory = htmlcov
