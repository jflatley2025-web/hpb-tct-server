# ────────────────────────────────────────────────
# HIGH PROBABILITY MODEL v17.3 (API + MULTI-SESSION ENABLED + RIG EXTENDED)
# Includes RCM (Range Context Module), MSCE (Multi-Session Context Engine),
# RIG (Range Integrity Gate), Live Data Bridge (OKX + Bybit + Coingecko),
# and Session Bias Tracking Output
# ────────────────────────────────────────────────

import numpy as np
from datetime import datetime, timedelta

# ────────────────────────────────────────────────
# IMPORT RIG VALIDATOR MODULE
# ────────────────────────────────────────────────
from hpb_rig_validator import range_integrity_validator

# ────────────────────────────────────────────────
# MULTI-SESSION CONTEXT ENGINE (MSCE)
# ────────────────────────────────────────────────
def validate_MSCE(context):
    """
    Multi-Session Context Evaluation (MSCE)
    Adds session weighting & bias transitions to gate confidence.
    """
    utc_hour = datetime.utcnow().hour
    session = "Asia"
    bias = "neutral"
    weight = 1.0

    if 0 <= utc_hour < 8:
        session = "Asia"
        weight = 0.95
    elif 8 <= utc_hour < 16:
        session = "London"
        weight = 1.05
    else:
        session = "NY"
        weight = 1.15

    context["MSCE"] = {
        "session": session,
        "session_bias": bias,
        "weight": weight,
        "valid": True,
        "confidence": weight
    }
    return context["MSCE"]

# ────────────────────────────────────────────────
# RANGE INTEGRITY GATE (RIG)
# ────────────────────────────────────────────────
def validate_RIG(context):
    """
    Range Integrity Gate (RIG)
    Prevents counter-bias setups when the high-time-frame range remains valid.
    Derived from HP-TCT model variables and Ranges_1_TREVIEW logic.
    """

    try:
        rig_result = range_integrity_validator(context)
        return rig_result
    except Exception as e:
        rcm = context.get("RCM", {})
        msce = context.get("MSCE", {})
        bias_htf = context.get("1A", {}).get("bias", "neutral")
        bias_session = msce.get("session_bias", bias_htf)
        range_valid = rcm.get("valid", False)
        duration = rcm.get("range_duration_hours", 0)
        local_disp = context.get("local_range_displacement", 0.0)

        if range_valid and duration >= 24 and local_disp < 0.25 and bias_htf != bias_session:
            return {
                "Gate": "RIG",
                "passed": False,
                "reason": "Counter-bias detected during intact HTF range",
                "confidence": 0.0,
                "htf_bias": bias_htf,
                "session_bias": bias_session,
            }
        return {
            "Gate": "RIG",
            "passed": True,
            "reason": None,
            "confidence": 1.0,
            "htf_bias": bias_htf,
            "session_bias": bias_session,
        }

# ────────────────────────────────────────────────
# VALIDATE GATES SEQUENCE (includes RIG + Range Chart Generation)
# ────────────────────────────────────────────────
from hpb_range_plotter import plot_range_chart

def validate_gates(context):
    """
    Validates all HPB gates in proper sequence (1A→1D) including
    RCM, MSCE, and RIG. Automatically generates a visual range chart
    whenever a valid range is detected.
    """
    context["1A"] = validate_1A(context)
    context["1B"] = validate_1B(context)
    context["1C"] = validate_1C(context)
    context["RCM"] = validate_RCM(context)
    context["MSCE"] = validate_MSCE(context)

    # ─────────────────────────────────────────────
    # RANGE CHART GENERATION (after RCM validation)
    # ─────────────────────────────────────────────
    try:
        if context.get("RCM", {}).get("valid", False):
            chart_path = plot_range_chart(context, save_dir="charts")
            context["RCM"]["chart_path"] = chart_path
            context["RCM"]["chart_generated"] = True
        else:
            context["RCM"]["chart_generated"] = False
    except Exception as e:
        context["RCM"]["chart_generated"] = False
        context["RCM"]["chart_error"] = str(e)

    # ─────────────────────────────────────────────
    # NEW RANGE INTEGRITY GATE
    # ─────────────────────────────────────────────
    context["RIG"] = validate_RIG(context)
    if not context["RIG"].get("passed", True):
        context["ExecutionConfidence_Total"] = 0.0
        context["Reward_Summary"] = "INVALID_RIG"
        context["RIG_reason"] = context["RIG"].get("reason", "")
        return context

    # ─────────────────────────────────────────────
    # FINAL EXECUTION GATE
    # ─────────────────────────────────────────────
    context["1D"] = validate_1D(context)
    return context

# ────────────────────────────────────────────────
# END OF FILE
# ────────────────────────────────────────────────

